{
  "name": "@monotykamary/folio",
  "version": "0.1.5",
  "description": "Book PDF pagination using @chenglou/pretext for text measurement and Chrome's native page breaking",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild src/browser-entry.ts --bundle --format=iife --global-name=FolioInit --outfile=vendor/folio.bundle.js --platform=browser",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:dead": "knip --no-progress",
    "prepare": "husky",
    "version": "npm run bundle && git add vendor/folio.bundle.js",
    "postversion": "git push && git push --tags"
  },
  "keywords": [
    "pdf",
    "book",
    "folio",
    "pretext",
    "pagination",
    "chrome",
    "print",
    "pagedjs-alternative"
  ],
  "author": "Cheng Lou",
  "files": [
    "vendor/folio.bundle.js",
    "src/",
    "docs/",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "type": "module",
  "peerDependencies": {
    "@chenglou/pretext": "^0.0.6"
  },
  "devDependencies": {
    "@chenglou/pretext": "^0.0.6",
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "esbuild": "^0.20.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "knip": "^6.12.2",
    "typescript": "^5.4.0",
    "vitest": "^4.1.5"
  }
}
